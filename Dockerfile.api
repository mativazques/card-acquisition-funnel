# Copilot API — reactive text-to-metric Q&A over the governed semantic layer.
# Python 3.12 (google-adk needs protobuf 6.x). Separate image from the cockpit, which
# pins protobuf<6 — the split that forces two venvs also forces two images.
# Multi-stage: deps compile in the builder venv, only the venv + app code ship.

FROM python:3.12-slim AS builder
WORKDIR /app
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
COPY agents/requirements.txt ./agents/requirements.txt
RUN pip install --no-cache-dir -r agents/requirements.txt

FROM python:3.12-slim
WORKDIR /app
ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1
COPY --from=builder /opt/venv /opt/venv
# Only the code the API imports: the agent layer wraps the framework-neutral semantic layer.
COPY agents/ ./agents/
COPY semantic/ ./semantic/
EXPOSE 8080
# Cloud Run injects $PORT; /health needs no key, the LLM is built lazily on first /ask.
CMD exec uvicorn agents.api:app --host 0.0.0.0 --port ${PORT:-8080}
