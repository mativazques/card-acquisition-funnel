# Copy to .env and fill in. .env is git-ignored — never commit real values.

# --- Kaggle API (kaggle.com -> Settings -> API -> Create New Token) ---
# IMPORTANT: accept the Santander Product Recommendation competition rules at
# https://www.kaggle.com/c/santander-product-recommendation under your Kaggle
# account before running `make hydrate`.
# Kaggle's current token is a bearer token (KGAT_...). ingest.py reads it from this
# var OR from ~/.kaggle/access_token. Either set it here or run:
#   mkdir -p ~/.kaggle && printf '%s' 'KGAT_...' > ~/.kaggle/access_token && chmod 600 ~/.kaggle/access_token
KAGGLE_API_TOKEN=your_kaggle_bearer_token

# --- GCP ---
# Use the project on matirvazques@gmail.com. Region MUST be US for GCS/BQ Always Free.
GCP_PROJECT=card-acquisition-funnel-2026
GCP_REGION=us-central1
GCS_BUCKET=card-acquisition-funnel-raw
BQ_DATASET=raw
BQ_DBT_DATASET=analytics
BQ_LOCATION=US

# --- Source dataset (Santander Product Recommendation, Kaggle competition 2016) ---
# Raw CSV is NOT committed. Reproduce via make hydrate after accepting competition rules.
KAGGLE_COMPETITION=santander-product-recommendation
KAGGLE_FILE=train_ver2.csv
BQ_RAW_TABLE=santander_customer_month
# Allow up to 100 malformed rows (known data-quality characteristic of this dataset).
BQ_MAX_BAD_RECORDS=100

# --- Copilot (Google AI Studio, free tier — https://aistudio.google.com/apikey) ---
# API-key auth, no billing attached: the free-tier daily quota is a hard $0 ceiling.
GEMINI_API_KEY=your_ai_studio_api_key
# Optional override; defaults to gemini-flash-lite-latest.
# COPILOT_MODEL=gemini-flash-lite-latest
